# ─── COPY THIS TO .env AND FILL IN YOUR VALUES ───

# MongoDB Atlas connection string (free tier works great)
# Get from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/rinl_cms?retryWrites=true&w=majority

# JWT Secret — make this a long random string, never share it
JWT_SECRET=rinl_vizag_steel_super_secret_jwt_key_2025_change_this_now

# Port (Render sets this automatically, leave as 5000 for local)
PORT=5000

# Your Vercel frontend URL (for CORS) — set after deploying frontend
CLIENT_URL=https://rinl-cms.vercel.app

# Anthropic API key for VISHWA AI chatbot (optional)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Set to production on Render
NODE_ENV=production
