# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/rinl_cms
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/rinl_cms

# JWT Secret (change to a strong random string in production)
JWT_SECRET=rinl_vizag_steel_jwt_secret_2025_change_me

# Server Port
PORT=5000

# Client URL (for CORS)
