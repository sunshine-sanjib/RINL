{
  "name": "rinl-cms",
  "version": "1.0.0",
  "description": "RINL Visakhapatnam Steel Plant - Contract Management System",
  "scripts": {
    "start": "node server/server.js",
    "build": "npm install && cd client && npm install && npm run build",
    "dev": "concurrently \"node server/server.js\" \"cd client && npm start\"",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": ["RINL", "VSP", "contract-management", "MERN"],
  "author": "RINL IT & ERP Department",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
